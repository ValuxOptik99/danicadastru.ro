# Copy this file to .env.local and fill in the real values.
# NEVER commit .env or .env.local — they are gitignored.

# Neon PostgreSQL — pooled connection (used by Next.js / Prisma runtime)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Neon PostgreSQL — direct/unpooled connection (used by Prisma migrations)
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Brevo (formerly Sendinblue) — https://app.brevo.com/settings/keys/api
BREVO_API_KEY=""
BREVO_SENDER_EMAIL="office@danicadastru.ro"
BREVO_SENDER_NAME="DANI Cadastru Website"
NOTIFICATION_EMAIL="office@danicadastru.ro"

# Admin panel (Etapa 6C)
ADMIN_PASSWORD=""
ADMIN_SESSION_SECRET=""
